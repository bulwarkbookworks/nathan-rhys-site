---
import { client } from '../lib/sanity';
import Layout from '../layouts/Layout.astro';
import { PortableText } from 'astro-portabletext';

export async function getStaticPaths() {
  const pages = await client.fetch(`*[_type == "standardPage"]{ "slug": slug.current }`);
  return pages.map((page: any) => ({
    params: { slug: page.slug },
  }));
}

const { slug } = Astro.params;

const page = await client.fetch(`*[_type == "standardPage" && slug.current == $slug][0]{
  ...,
  "layout": layout->{
    ...,
    topNavigation->{
      items[]{
        label,
        link{
          ...,
          internal->{ _type, slug }
        }
      }
    }
  }
}`, { slug });

if (!page) {
  return Astro.redirect('/404');
}
---

<Layout title={page.title} metadata={page.metadata}>
  <main class="container py-20">
    <div class="standard-page">
      <h1>{page.title}</h1>
      <div class="standard-page__content mt-8">
        <PortableText value={page.content} />
      </div>
    </div>
  </main>
</Layout>

<style is:global>
  .standard-page__content {
    line-height: 1.6;
    font-size: 1.125rem;
  }
  .standard-page__content p {
    margin-bottom: 1.5rem;
  }
  .standard-page__content h2 {
    font-size: 2rem;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    font-family: 'Marcellus', serif;
  }
  .standard-page__content h3 {
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-family: 'Marcellus', serif;
  }
  .standard-page__content ul, .standard-page__content ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }
  .standard-page__content li {
    margin-bottom: 0.5rem;
  }
</style>
