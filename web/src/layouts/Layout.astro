---
import { client, urlFor, resolveLink, NAVIGATION_FIELDS, GLOBAL_LAYOUT_QUERY, FOOTER_QUERY } from '../lib/sanity';
import Navigation from '../components/Navigation.astro';
import 'bootstrap-icons/font/bootstrap-icons.css';
import '../styles/global.css';
import '../styles/main.scss';

interface Props {
  title: string;
  metadata?: any;
  showTopNav?: boolean;
  displayLastUpdated?: boolean;
  updatedAt?: string;
  mainClass?: string;
}

const { title, metadata, showTopNav = true, displayLastUpdated, updatedAt, mainClass } = Astro.props;

const siteMetadata = await client.fetch(`*[_type == "siteMetadata"][0].metadata`);

const layout = await client.fetch(GLOBAL_LAYOUT_QUERY);
const footer = await client.fetch(FOOTER_QUERY);

const navigation = layout?.topNavigation;
const navItems = navigation?.items?.length ? navigation.items : [
  { label: 'Home', link: '/' },
  { label: 'Books', link: '/#featured-book' },
  { label: 'Gallery', link: '/gallery' },
  { label: 'Artists', link: '/artists' },
  { label: 'About', link: '/#author' },
];

const footerBrand = footer?.siteInfo?.publisherInfo || 'Nathan Rhys';
const footerCopyright = footer?.copyrightArea?.copyrightText || footer?.siteInfo?.copyrightNotice || 'Nathan Rhys. All rights reserved.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    {layout?.faviconIcoUrl && <link rel="icon" href={layout.faviconIcoUrl} sizes="any" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {layout?.favicon16 && <link rel="icon" type="image/png" sizes="16x16" href={urlFor(layout.favicon16).width(16).height(16).auto('format').url()} />}
    {layout?.favicon32 && <link rel="icon" type="image/png" sizes="32x32" href={urlFor(layout.favicon32).width(32).height(32).auto('format').url()} />}
    {layout?.logoAppleTouch && <link rel="apple-touch-icon" href={urlFor(layout.logoAppleTouch).width(180).height(180).auto('format').url()} />}
    <meta name="generator" content={Astro.generator} />
    {metadata?.excludeFromSitemap && <meta name="robots" content="noindex, nofollow" />}
    <title>{metadata?.metaTitle || siteMetadata?.metaTitle || title}</title>
    <meta name="description" content={metadata?.metaDescription || siteMetadata?.metaDescription || ""} />

    {(metadata?.ogTitle || siteMetadata?.ogTitle) && <meta property="og:title" content={metadata?.ogTitle || siteMetadata?.ogTitle} />}
    {(metadata?.ogDescription || siteMetadata?.ogDescription) && <meta property="og:description" content={metadata?.ogDescription || siteMetadata?.ogDescription} />}
    {(metadata?.ogImage || siteMetadata?.ogImage) && <meta property="og:image" content={urlFor(metadata?.ogImage || siteMetadata?.ogImage).width(1200).height(630).auto('format').url()} />}
    {(metadata?.ogType || siteMetadata?.ogType) && <meta property="og:type" content={metadata?.ogType || siteMetadata?.ogType} />}

    {(metadata?.twitterCard || siteMetadata?.twitterCard) && <meta name="twitter:card" content={metadata?.twitterCard || siteMetadata?.twitterCard} />}
    {(metadata?.twitterTitle || siteMetadata?.twitterTitle) && <meta name="twitter:title" content={metadata?.twitterTitle || siteMetadata?.twitterTitle} />}
    {(metadata?.twitterDescription || siteMetadata?.twitterDescription) && <meta name="twitter:description" content={metadata?.twitterDescription || siteMetadata?.twitterDescription} />}
    {(metadata?.twitterImage || siteMetadata?.twitterImage) && <meta name="twitter:image" content={urlFor(metadata?.twitterImage || siteMetadata?.twitterImage).width(1200).height(600).auto('format').url()} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,650;14..32,750&family=Literata:opsz,wght@7..72,400;7..72,500;7..72,650&family=Marcellus&display=swap" rel="stylesheet" />
    <link rel="alternate" type="application/rss+xml" title="Nathan Rhys Newsletter" href="/rss.xml" />
    <style>
      .last-updated-container {
        padding-top: 2rem;
        padding-bottom: 0;
      }
      .last-updated {
        font-family: var(--font-sans, sans-serif);
        font-size: 0.875rem;
        color: var(--color-text-muted, #888);
        text-transform: lowercase;
        margin-bottom: 0;
      }
    </style>
    <slot name="head" />
  </head>
  <body>
    {showTopNav && <Navigation items={navItems} variant="top" logo={layout?.logoOriginal} />}
    <main class:list={["site-main", mainClass]}>
      {displayLastUpdated && updatedAt && (
        <div class="container last-updated-container">
          <p class="last-updated">
            last updated: {new Date(updatedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </p>
        </div>
      )}
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container site-footer__main">
        <div class="row">
          <div class="col-lg-4 mb-12 mb-lg-0">
            <p class="site-footer__brand">{footerBrand}</p>
            {footer?.siteInfo?.shortDescription && <p class="site-footer__description lede mt-4 mb-0">{footer.siteInfo.shortDescription}</p>}
            {footer?.siteInfo?.publisherInfo && <p class="site-footer__publisher mt-4">{footer.siteInfo.publisherInfo}</p>}
          </div>
          
          <div class="col-lg-8">
            <div class="row">
              {footer?.navigationGroups?.map((group: any) => (
                group.items?.length > 0 && (
                  <div class="col-6 col-md-4 mb-8 mb-md-0">
                    <h3 class="site-footer__heading">{group.title}</h3>
                    <ul class="site-footer__list list-unstyled mt-4 space-y-2">
                      {group.items.map((item: any) => (
                        <li>
                          <a href={resolveLink(item.link)} class="site-footer__link hover:text-accent">
                            {item.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )
              ))}

              {footer?.legalNavigation?.items?.length > 0 && (
                <div class="col-6 col-md-4 mb-8 mb-md-0">
                  <h3 class="site-footer__heading">{footer.legalNavigation.title || 'Legal'}</h3>
                  <ul class="site-footer__list list-unstyled mt-4 space-y-2">
                    {footer.legalNavigation.items.map((item: any) => (
                      <li>
                        <a href={resolveLink(item.link)} class="site-footer__link hover:text-accent">
                          {item.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {footer?.socialLinks?.filter((l: any) => l.enabled).length > 0 && (
                <div class="col-6 col-md-4">
                  <h3 class="site-footer__heading">Connect</h3>
                  <ul class="site-footer__list list-unstyled mt-4 space-y-2">
                    {footer.socialLinks.filter((l: any) => l.enabled).map((social: any) => (
                      <li>
                        <a href={resolveLink(social.link)} target={social.openInNewTab ? "_blank" : undefined} rel="noopener noreferrer" class="site-footer__link flex items-center gap-2 hover:text-accent">
                          {social.icon && <i class={`bi bi-${social.icon}`}></i>}
                          <span>{social.platform}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>

      <div class="site-footer__bottom mt-16 pt-8 border-t border-white/5">
        <div class="container">
          <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-xs tracking-widest uppercase opacity-60">
            <p>&copy; {new Date().getFullYear()} {footerCopyright}</p>
            <div class="flex gap-6">
              {footer?.copyrightArea?.publisherName && <span>{footer.copyrightArea.publisherName}</span>}
              {footer?.copyrightArea?.secondaryText && <span>{footer.copyrightArea.secondaryText}</span>}
            </div>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
