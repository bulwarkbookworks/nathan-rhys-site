---
import Card from './Card.astro';

interface Props {
  section: any;
}

const { section } = Astro.props;
const columns = section.columns || '3';
---

<div class:list={[
  'cards-grid grid gap-8',
  columns === '2' ? 'md:grid-cols-2' : 'md:grid-cols-2 lg:grid-cols-3'
]}>
  {section.cards?.map((card: any) => (
    <Card card={card} />
  ))}
</div>
