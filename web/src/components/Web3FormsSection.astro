---
interface Props {
  section: {
    kicker?: string;
    heading?: string;
    content?: {
      code?: string;
      language?: string;
      filename?: string;
    };
    form?: {
      formId?: string;
      submitButtonText?: string;
      redirectPath?: string;
      customFields?: Array<{
        label: string;
        name: string;
        type: 'text' | 'email' | 'textarea' | 'tel' | 'number';
        placeholder?: string;
        required?: boolean;
        width?: 'full' | 'half';
      }>;
    };
  };
}

const { section } = Astro.props;
const form = section.form || {};

// Map Form ID to specific Environment Variables
// We support WEB3FORMS_ACCESS_KEY_CONTACT, etc.
const formIdKey = `WEB3FORMS_ACCESS_KEY_${form.formId || 'CONTACT'}`;
const accessKey = import.meta.env[formIdKey] || import.meta.env.WEB3FORMS_ACCESS_KEY;

const requireTurnstile = import.meta.env.WEB3FORMS_REQUIRE_TURNSTILE === "true";
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
const isProd = import.meta.env.PROD;
const showWarning = !accessKey && !isProd;

// Use the current URL for full redirect path if redirectPath is relative
const baseUrl = Astro.url.origin;
const redirectUrl = form.redirectPath 
  ? (form.redirectPath.startsWith('http') ? form.redirectPath : `${baseUrl}${form.redirectPath}`)
  : undefined;

const formSubject = section.heading || `New ${form.formId || 'Website'} Submission`;
---

<div class="web3forms-section max-w-2xl">
  {showWarning && (
    <div class="bg-rust/20 border border-rust text-text-main p-4 rounded-lg mb-8">
      <p class="font-bold">Development Warning:</p>
      <p><code>{formIdKey}</code> (or fallback <code>WEB3FORMS_ACCESS_KEY</code>) is missing from your environment variables. The form will not submit correctly.</p>
    </div>
  )}

  <div class="form-intro mb-8">
    {section.content?.code && (
      <div class="code-intro">
        {section.content.filename && (
          <div class="text-xs font-mono text-text-muted mb-2 px-2">{section.content.filename}</div>
        )}
        <pre class="bg-surface-soft p-6 rounded-xl overflow-x-auto border border-white/10 font-mono text-sm leading-relaxed text-secondary shadow-inner"><code>{section.content.code}</code></pre>
      </div>
    )}
  </div>

  <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
    <input type="hidden" name="access_key" value={accessKey} />
    <input type="hidden" name="subject" value={formSubject} />
    {redirectUrl && <input type="hidden" name="redirect" value={redirectUrl} />}
    
    <!-- Honeypot -->
    <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

    <div class="grid md:grid-cols-2 gap-6">
      {(!form.customFields || form.customFields.length === 0) ? (
        <>
          <div class="form-group">
            <label for="name" class="block text-sm font-bold mb-2 uppercase tracking-wider text-secondary">Full Name</label>
            <input 
              type="text" 
              name="name" 
              id="name" 
              required 
              placeholder="John Doe"
              class="w-full bg-surface-soft border border-white/10 rounded-lg px-4 py-3 text-text-main focus:outline-none focus:border-accent transition-colors"
            />
          </div>
          <div class="form-group">
            <label for="email" class="block text-sm font-bold mb-2 uppercase tracking-wider text-secondary">Email Address</label>
            <input 
              type="email" 
              name="email" 
              id="email" 
              required 
              placeholder="john@example.com"
              class="w-full bg-surface-soft border border-white/10 rounded-lg px-4 py-3 text-text-main focus:outline-none focus:border-accent transition-colors"
            />
          </div>
          <div class="form-group md:col-span-2">
            <label for="subject_display" class="block text-sm font-bold mb-2 uppercase tracking-wider text-secondary">Subject</label>
            <input 
              type="text" 
              name="subject_display" 
              id="subject_display" 
              required 
              placeholder="How can I help you?"
              class="w-full bg-surface-soft border border-white/10 rounded-lg px-4 py-3 text-text-main focus:outline-none focus:border-accent transition-colors"
            />
          </div>
          <div class="form-group md:col-span-2">
            <label for="message" class="block text-sm font-bold mb-2 uppercase tracking-wider text-secondary">Message</label>
            <textarea 
              name="message" 
              id="message" 
              rows="5" 
              required 
              placeholder="Your message here..."
              class="w-full bg-surface-soft border border-white/10 rounded-lg px-4 py-3 text-text-main focus:outline-none focus:border-accent transition-colors"
            ></textarea>
          </div>
        </>
      ) : (
        form.customFields.map((field: any) => (
          <div class:list={["form-group", field.width === 'full' ? 'md:col-span-2' : '']}>
            <label for={field.name} class="block text-sm font-bold mb-2 uppercase tracking-wider text-secondary">{field.label}</label>
            {field.type === 'textarea' ? (
              <textarea 
                name={field.name} 
                id={field.name} 
                rows="5" 
                required={field.required} 
                placeholder={field.placeholder}
                class="w-full bg-surface-soft border border-white/10 rounded-lg px-4 py-3 text-text-main focus:outline-none focus:border-accent transition-colors"
              ></textarea>
            ) : (
              <input 
                type={field.type} 
                name={field.name} 
                id={field.name} 
                required={field.required} 
                placeholder={field.placeholder}
                class="w-full bg-surface-soft border border-white/10 rounded-lg px-4 py-3 text-text-main focus:outline-none focus:border-accent transition-colors"
              />
            )}
          </div>
        ))
      )}
    </div>

    {requireTurnstile && turnstileSiteKey && (
      <div class="form-group">
        <div class="cf-turnstile" data-sitekey={turnstileSiteKey}></div>
        <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
      </div>
    )}

    <div>
      <button 
        type="submit" 
        class="inline-block px-10 py-4 rounded-full font-bold bg-secondary text-background-deep hover:bg-accent transition-all cursor-pointer"
      >
        {form.submitButtonText || 'Send Message'}
      </button>
    </div>
  </form>
</div>

<style>
  .web3forms-section {
    /* Additional styles if needed */
  }
  
  /* Ensure form elements inherit font */
  input, textarea, button {
    font-family: inherit;
  }
</style>