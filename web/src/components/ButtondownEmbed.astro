---
import { getButtondownUrls } from '../lib/buttondown';

interface Props {
  username: string;
  emailLabel?: string;
  displayType: 'form' | 'iframe';
}

const { username, emailLabel = "Enter your email", displayType } = Astro.props;
const urls = getButtondownUrls(username);
---

{displayType === 'form' ? (
  <form
    action={urls.formAction}
    method="post"
    target="popupwindow"
    onsubmit={`window.open('${urls.newsletterPage}', 'popupwindow')`}
    class="embeddable-buttondown-form"
  >
    <div class="flex flex-col sm:flex-row gap-4 items-end">
      <div class="flex-grow w-full">
        <label for="bd-email" class="block text-sm font-medium mb-2 opacity-80">{emailLabel}</label>
        <input 
          type="email" 
          name="email" 
          id="bd-email" 
          required
          placeholder="email@example.com"
          class="w-full bg-white/5 border border-white/20 rounded px-4 py-3 text-white focus:outline-none focus:border-accent transition-colors"
        />
      </div>
      <button type="submit" class="cta cta--primary whitespace-nowrap">
        Subscribe
      </button>
    </div>
    <p class="mt-4 text-sm opacity-60">
      <a href={urls.referrer} target="_blank" class="hover:text-accent transition-colors">
        Powered by Buttondown.
      </a>
    </p>
  </form>
) : (
  <iframe
    scrolling="no"
    style="width:100%;height:220px;border:1px rgba(255,255,255,0.1) solid; border-radius: 8px;"
    src={urls.iframeSrc}
  ></iframe>
)}

<style>
  /* You can add specific styles for the form here if needed */
  .embeddable-buttondown-form {
    max-width: 500px;
  }
</style>
