---
import { urlFor, generateSrcset } from '../lib/sanity';
import { PortableText } from 'astro-portabletext';

interface Props {
  steps: any[];
}

const { steps } = Astro.props;
---

<ol class="process-flow" role="list">
  {steps?.map((step: any, index: number) => (
    <li
      class:list={[
        'process-step',
        index % 2 === 1 && 'process-step--reverse',
        step.screenshot && 'process-step--has-image'
      ]}
      id={step._id}
    >
      <div class="process-step__waypoint" aria-hidden="true">
        <span class="process-step__icon">
          {step.iconType === 'glyphicon' && step.glyphicon && (
            <i class:list={['bi', step.glyphicon]}></i>
          )}
          {step.iconType === 'image' && step.imageIcon && (
            <img
              src={urlFor(step.imageIcon).width(64).height(64).auto('format').url()}
              alt=""
              loading="lazy"
              decoding="async"
            />
          )}
          {(!step.iconType || (step.iconType === 'glyphicon' && !step.glyphicon) || (step.iconType === 'image' && !step.imageIcon)) && (
            <span>{index + 1}</span>
          )}
        </span>
      </div>

      <article class="process-step__card">
        <header class="process-step__header">
          <p class="process-step__eyebrow">Part of the process</p>
          <h2>{step.title}</h2>
        </header>

        <div class:list={[
          'process-step__body',
          step.screenshot && 'process-step__body--split'
        ]}>
          <div class="process-step__copy">
            {step.shortBlurb && (
              <div class="process-step__blurb">
                {Array.isArray(step.shortBlurb) ? (
                  <PortableText value={step.shortBlurb} />
                ) : (
                  <p>{step.shortBlurb}</p>
                )}
              </div>
            )}

            {step.reasoning && (
              <aside class="process-step__reasoning">
                <p class="process-step__reasoning-title">Why it belongs here</p>
                <div class="process-step__reasoning-copy">
                  <PortableText value={step.reasoning} />
                </div>
              </aside>
            )}
          </div>

          {step.screenshot && (
            <figure class="process-step__figure">
              <div class="process-step__image">
                <img
                  src={urlFor(step.screenshot).width(1600).auto('format').url()}
                  srcset={generateSrcset(step.screenshot, [480, 768, 1100, 1400, 1800])}
                  sizes="(max-width: 959px) 92vw, 48vw"
                  alt={step.screenshotAlt || step.screenshotCaption || `Screenshot illustrating ${step.title}`}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              {step.screenshotCaption && (
                <figcaption>{step.screenshotCaption}</figcaption>
              )}
            </figure>
          )}
        </div>

        {step.substeps?.length > 0 && (
          <div class="process-step__substeps" role="list" aria-label={`${step.title} details`}>
            {step.substeps.map((substep: any) => (
              <section class="process-substep" role="listitem">
                <div class="process-substep__marker" aria-hidden="true"></div>
                <div>
                  <h3>{substep.title}</h3>
                  {substep.content && (
                    <div class="process-substep__content">
                      <PortableText value={substep.content} />
                    </div>
                  )}
                </div>
              </section>
            ))}
          </div>
        )}
      </article>
    </li>
  ))}
</ol>
