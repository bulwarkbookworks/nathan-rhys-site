---
import Layout from '../layouts/Layout.astro';
import PageSection from './PageSection.astro';
import JourneyTimeline from './JourneyTimeline.astro';
import WorkshopGrid from './WorkshopGrid.astro';
import MailerliteUniversal from './MailerliteUniversal.astro';

const { page } = Astro.props;

const allSections = [
  ...(page.journeySections || []),
  ...(page.workshopSections || []),
  ...(page.postWorkshopSections || [])
];

const hasMailerlite = allSections.some((section: any) =>
  section._type === 'mailerliteSection' ||
  section.ctas?.some((cta: any) => cta._type === 'mailerliteCTA')
);
---

<Layout
  title={page.title}
  metadata={page.metadata}
  displayLastUpdated={page.displayLastUpdated}
  updatedAt={page._updatedAt}
  mainClass="how-i-work-page"
>
  {hasMailerlite && <MailerliteUniversal slot="head" />}

  <header class="how-i-work-hero">
    <div class="container">
      <p class="how-i-work-hero__eyebrow">Behind the stories</p>
      <h1>{page.title}</h1>
    </div>
  </header>

  <div class="how-i-work-shell container">
    {page.journeySections?.length > 0 && (
      <section class="how-i-work-standard how-i-work-standard--journey-intro">
        {page.journeySections.map((section: any) => (
          <PageSection section={section} />
        ))}
      </section>
    )}

    {page.journeySteps?.length > 0 && (
      <section class="how-i-work-journey" aria-label="The writing journey">
        <JourneyTimeline steps={page.journeySteps} />
      </section>
    )}

    {page.workshopSections?.length > 0 && (
      <section class="how-i-work-standard how-i-work-standard--workshop-intro">
        {page.workshopSections.map((section: any) => (
          <PageSection section={section} />
        ))}
      </section>
    )}

    {page.workshopTools?.length > 0 && (
      <section class="how-i-work-workshop" aria-label="Tools in the workshop">
        <WorkshopGrid tools={page.workshopTools} />
      </section>
    )}

    {page.postWorkshopSections?.length > 0 && (
      <section class="how-i-work-standard how-i-work-standard--closing">
        {page.postWorkshopSections.map((section: any) => (
          <PageSection section={section} />
        ))}
      </section>
    )}
  </div>
</Layout>
