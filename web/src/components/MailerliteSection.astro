---
import { PortableText } from 'astro-portabletext';

interface Props {
  section: {
    kicker?: string;
    heading?: string;
    content?: any;
    form?: {
      formId: string;
    };
    alignment?: 'left' | 'center';
  };
}

const { section } = Astro.props;
const form = section.form;
const alignmentClass = section.alignment === 'left' ? 'text-left' : 'text-center mx-auto';
---

<div class:list={["mailerlite-section", alignmentClass]}>
  {section.content && (
    <div class="rich-text-content mb-8 text-text-muted leading-relaxed max-w-2xl mx-auto">
      <PortableText value={section.content} />
    </div>
  )}

  {form && (
    <div class="mailerlite-form-container mt-10">
        <div class="ml-embedded" data-form={form.formId}></div>
    </div>
  )}
</div>

<style is:global>
  /* Basic styling for MailerLite form to ensure it fits the theme */
  .ml-embedded {
    margin: 0 auto;
  }
</style>
