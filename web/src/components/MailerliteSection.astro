---
import { PortableText } from 'astro-portabletext';

interface Props {
  section: {
    kicker?: string;
    heading?: string;
    content?: any;
    form?: {
      formId: string;
      accountId?: string;
    };
    alignment?: 'left' | 'center';
  };
}

const { section } = Astro.props;
const form = section.form;
const alignmentClass = section.alignment === 'left' ? 'text-left' : 'text-center mx-auto';
const accountId = form?.accountId || import.meta.env.PUBLIC_MAILERLITE_ACCOUNT_ID;
---

<div class:list={["mailerlite-section", alignmentClass]}>
  {section.content && (
    <div class="rich-text-content mb-8 text-text-muted leading-relaxed max-w-2xl mx-auto">
      <PortableText value={section.content} />
    </div>
  )}

  {form && (
    <div class="mailerlite-form-container mt-10">
        {/* MailerLite Universal Script */}
        {accountId && (

          <!-- MailerLite Universal -->
          <script>
            (function(w,d,e,u,f,l,n){w[f]=w[f]||function(){(w[f].q=w[f].q||[])
              .push(arguments);},l=d.createElement(e),l.async=1,l.src=u,
              n=d.getElementsByTagName(e)[0],n.parentNode.insertBefore(l,n);})
            (window,document,'script','https://assets.mailerlite.com/js/universal.js','ml');
            ml('account', 'accountId');
            </script>
          <!-- End MailerLite Universal -->

        )}
        <div class="ml-embedded" data-form={form.formId}></div>
    </div>
  )}
</div>

<style is:global>
  /* Basic styling for MailerLite form to ensure it fits the theme */
  .ml-embedded {
    margin: 0 auto;
  }
</style>
