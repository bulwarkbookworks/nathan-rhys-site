---
interface Props {
  cta: {
    label: string;
    form?: {
      formId: string;
    };
    style?: 'primary' | 'secondary' | 'ghost';
  };
}

const { cta } = Astro.props;
const form = cta.form;

const styleClasses = {
  primary: 'bg-secondary text-background-deep hover:bg-accent',
  secondary: 'bg-surface-soft text-text-main border border-white/10 hover:border-accent',
  ghost: 'bg-transparent text-secondary border border-secondary hover:bg-secondary hover:text-background-deep',
};

const currentStyle = cta.style || 'primary';
---

{form && (
  <button 
    data-ml-form={form.formId}
    class:list={[
      "mailerlite-cta inline-block px-10 py-4 rounded-full font-bold transition-all cursor-pointer",
      styleClasses[currentStyle]
    ]}
  >
    {cta.label}
  </button>
)}

<script>
  function setupMailerLiteCTA(button: HTMLButtonElement) {
    button.addEventListener('click', () => {
      const formId = button.getAttribute('data-ml-form');
      
      if (typeof window !== 'undefined' && (window as any).ml && formId) {
        (window as any).ml('show', formId, true);
      }
    });
  }

  // Initialize buttons
  const buttons = document.querySelectorAll('.mailerlite-cta');
  buttons.forEach(button => setupMailerLiteCTA(button as HTMLButtonElement));
</script>
