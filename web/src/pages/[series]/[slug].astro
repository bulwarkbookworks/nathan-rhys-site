---
import { client } from '../../lib/sanity';
import BookTemplate from '../../components/BookTemplate.astro';

export async function getStaticPaths() {
  const booksWithSeries = await client.fetch(`*[_type == "book" && defined(series)]{ 
    "slug": slug.current, 
    "seriesSlug": series->slug.current 
  }`);
  
  // Filter out any where series slug might be missing
  return booksWithSeries
    .filter((b: any) => b.seriesSlug && b.slug)
    .map((b: any) => ({ 
      params: { series: b.seriesSlug, slug: b.slug },
      props: { type: 'book' }
    }));
}

const { series, slug } = Astro.params;

const SECTION_QUERY = `
  sections[]{
    ...,
    ctas[]{
      ...,
      link{
        ...,
        internal->{
          ...,
          _type == "book" => {
            "seriesSlug": series->slug.current
          },
          _type == "buttondownEmbed" => {
            "username": username.current
          }
        }
      }
    },
    _type == "listSection" => {
      items[]{
        ...,
        content[],
        glyphiconColor
      }
    },
    _type == "richTextSection" => {
      content[]
    },
    _type == "buttondownEmbedSection" => {
      embed->{
        "username": username.current,
        emailLabel
      }
    }
  }
`;

const data = await client.fetch(`*[_type == "book" && slug.current == $slug && series->slug.current == $series][0]{ 
  ..., 
  series->{ name, slug }, 
  "seriesSlug": series->slug.current,
  chapters[]->{ title, slug },
  ${SECTION_QUERY}
}`, { series, slug });

if (!data) {
  return Astro.redirect('/404');
}
---

<BookTemplate book={data} />
