---
import { client, urlFor } from '../lib/sanity';
import '../styles/global.css';
import '../styles/main.scss';

const home = await client.fetch(`*[_type == "home"][0]{
	title,
	blurb,
	heroImage,
	series[]->{
		name,
		books[]->{
			title,
			slug,
			cover,
			status,
			releaseDate,
			projectedRelease,
			releaseDateTbd,
			blurb
		}
	}
}`);

const generateSrcset = (image: any, widths: number[], ratio?: number) => {
	if (!image) return '';
	return widths
		.map(w => {
			let builder = urlFor(image).width(w).auto('format');
			if (ratio) builder = builder.height(Math.round(w * ratio));
			return `${builder.url()} ${w}w`;
		})
		.join(', ');
};

const heroWidths = [400, 800, 1200, 1600, 2000];
const bookWidths = [300, 600, 900];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{home?.title || 'Nathan Rhys'}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
	</head>
	<body>
		<header class="relative">
			{home?.heroImage && (
				<div class="relative w-full overflow-hidden">
					<img 
						src={urlFor(home.heroImage).width(1200).auto('format').url()} 
						srcset={generateSrcset(home.heroImage, heroWidths)}
						sizes="100vw"
						alt="" 
						class="w-full h-auto block scale-[1.25] md:scale-100 transition-transform duration-700"
					/>
					<div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-background to-transparent"></div>
				</div>
			)}
			<div class="relative z-10 mt-n2 mt-md-n5 mt-sm-n3">
				<div class="bg-primary/40 backdrop-blur-xl px-10 py-12 md:py-16 border-white/10 shadow-2xl w-full">
					<div class="container">
						<h1 class="text-6xl md:text-8xl font-bold mb-4 tracking-tight text-white leading-none">{home?.title || 'Welcome'}</h1>
						{home?.blurb && <p class="text-xl md:text-2xl text-text-muted italic leading-relaxed">{home.blurb}</p>}
					</div>
				</div>
			</div>
		</header>

		<main class="container pt-16 md:pt-24 pb-20">
			{home?.series && home.series.length > 0 && home.series.map((s: any) => (
				<section class="mb-24 last:mb-0">
					<h2 class="text-4xl font-serif font-bold mb-12 text-secondary border-b border-secondary/20 pb-4">{s.name}</h2>
					<div class="row g-5">
						{s.books?.map((book: any) => (
							<div class="col-md-6 col-lg-4">
								<a href={`/books/${book.slug?.current}`} class="block h-full no-underline group">
									<div class="flex flex-col h-full bg-surface/50 rounded-xl overflow-hidden border border-white/5 hover:border-accent/40 hover:bg-surface/80 transition-all duration-300 shadow-lg hover:shadow-accent/5">
										{book.cover && (
											<div class="aspect-[2/3] overflow-hidden">
												<img 
													src={urlFor(book.cover).width(600).height(900).auto('format').url()} 
													srcset={generateSrcset(book.cover, bookWidths, 1.5)}
													sizes="(max-width: 768px) 90vw, (max-width: 1024px) 45vw, 400px"
													alt={book.title}
													class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
												/>
											</div>
										)}
										<div class="p-5 flex flex-col flex-grow">
											<h3 class="text-2xl font-serif font-bold mb-1 text-white group-hover:text-accent transition-colors">{book.title}</h3>
											
											<div class="flex flex-wrap gap-2 mb-3">
												{book.status && (
													<span class="px-2 py-1 bg-accent/10 text-accent text-xs font-semibold uppercase tracking-wider rounded">
														{book.status}
													</span>
												)}
												
												<span class="px-2 py-1 bg-secondary/10 text-secondary text-xs font-semibold uppercase tracking-wider rounded">
													{book.releaseDate ? new Date(book.releaseDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) : 
													 book.projectedRelease ? book.projectedRelease : 
													 book.releaseDateTbd ? 'TBD' : 'Unknown'}
												</span>
											</div>

											{book.blurb && (
												<p class="text-text-muted line-clamp-3 text-sm leading-relaxed mb-0">
													{book.blurb}
												</p>
											)}
										</div>
									</div>
								</a>
							</div>
						))}
					</div>
				</section>
			))}
		</main>

		<footer class="py-12 border-t border-secondary/20 bg-background/80 text-center text-text-muted text-sm">
			<div class="container">
				<p class="tracking-widest uppercase mb-2">Nathan Rhys</p>
				<p>&copy; {new Date().getFullYear()} Nathan Rhys. All rights reserved.</p>
			</div>
		</footer>
	</body>
</html>
