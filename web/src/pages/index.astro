---
import { client, urlFor, resolveLink } from '../lib/sanity';
import Navigation from '../components/Navigation.astro';
import Layout from '../layouts/Layout.astro';

const linkField = `
  link {
    ...,
    internal->{ _type, slug }
  }
`;

const ctasField = `
  ctas[]{
    label,
    style,
    ${linkField}
  }
`;

const home = await client.fetch(`*[_type == "home"][0]{
  ...,
  ${ctasField},
  featuredBook->{
    title,
    subtitle,
    slug,
    cover,
    status,
    releaseDate,
    projectedRelease,
    releaseDateTbd,
    blurb,
    ${ctasField},
    featureKicker
  },
  brandPillars[]->{title, body},
  series[]->{
    name,
    books[]->{
      title,
      subtitle,
      slug,
      cover,
      status,
      releaseDate,
      projectedRelease,
      releaseDateTbd,
      blurb,
      ${ctasField},
      featureKicker
    }
  }
}`);

const navigation = await client.fetch(`*[_type == "navigation"][0]{ 
  items[]{
    label,
    ${linkField}
  } 
}`);

const fallbackBook = home?.featuredBook || home?.series?.[0]?.books?.[0];

const generateSrcset = (image: any, widths: number[], ratio?: number) => {
  if (!image) return '';
  return widths
    .map((w) => {
      let builder = urlFor(image).width(w).auto('format');
      if (ratio) builder = builder.height(Math.round(w * ratio));
      return `${builder.url()} ${w}w`;
    })
    .join(', ');
};

const formatRelease = (book: any) => {
  if (!book) return '';
  if (book.releaseDate) {
    return new Date(book.releaseDate).toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric',
    });
  }
  if (book.projectedRelease) return book.projectedRelease;
  if (book.releaseDateTbd) return 'Release date to be announced';
  return '';
};

const heroWidths = [640, 960, 1280, 1600, 2200];
const coverWidths = [360, 540, 720, 900];

const siteTitle = home?.title || 'Nathan Rhys';
const eyebrow = home?.eyebrow || 'Nathan Rhys';
const tagline = home?.tagline || 'Fantasy where meaning has weight.';
const blurb = home?.blurb || 'Modern fantasy about hidden beauty, costly courage, and the burden of protecting what is good.';

const navItems = navigation?.items?.length ? navigation.items : [
  { label: 'Home', link: '/' },
  { label: 'Books', link: '#featured-book' },
  { label: 'About', link: '#author' },
];

const homeCtas = home?.ctas?.length ? home.ctas.map((cta: any) => ({
  ...cta,
  link: resolveLink(cta.link)
})) : [
  { 
    label: 'Read the Sample', 
    link: fallbackBook?.slug?.current ? `/books/${fallbackBook.slug.current}` : '#featured-book', 
    style: 'primary' 
  },
  { 
    label: 'Explore the Book', 
    link: '#featured-book', 
    style: 'secondary' 
  }
];

const pillars = home?.brandPillars?.length ? home.brandPillars : [
  { title: 'Beauty with consequence', body: 'Wonder matters more when the world is broken enough to need it.' },
  { title: 'Courage under burden', body: 'The strongest characters are not untouched by fear; they choose anyway.' },
  { title: 'Hope with teeth', body: 'The darkness is real, but it does not get the final word.' },
];
---

<Layout 
  title={siteTitle} 
  metadata={home?.metadata} 
  showTopNav={false}
>
    <header class="site-hero">
      {home?.heroImage && (
        <picture class="site-hero__media" aria-hidden="true">
          <img
            src={urlFor(home.heroImage).width(1600).auto('format').url()}
            srcset={generateSrcset(home.heroImage, heroWidths)}
            sizes="100vw"
            alt=""
            class="site-hero__image"
          />
        </picture>
      )}

      <div class="site-hero__shade"></div>

      <div class="container site-hero__content">
        <p class="eyebrow">{eyebrow}</p>
        <h1>{tagline}</h1>
        <p class="lede">{blurb}</p>
        <div class="cta-row" aria-label="Primary actions">
          {homeCtas.map((cta: any) => (
            <a class={`button button--${cta.style || 'primary'}`} href={cta.link}>{cta.label}</a>
          ))}
        </div>
      </div>
    </header>

    <Navigation items={navItems} variant="home" />

    <main>
      {fallbackBook && (
        <section id="featured-book" class="section section--featured">
          <div class="container">
            <div class="feature-card">
              {fallbackBook.cover && (
                <a class="book-cover-link" href={fallbackBook.slug?.current ? `/books/${fallbackBook.slug.current}` : '#'} aria-label={`View ${fallbackBook.title}`}>
                  <img
                    src={urlFor(fallbackBook.cover).width(720).height(1080).auto('format').url()}
                    srcset={generateSrcset(fallbackBook.cover, coverWidths, 1.5)}
                    sizes="(max-width: 768px) 70vw, 360px"
                    alt={`${fallbackBook.title} cover`}
                    class="book-cover"
                  />
                </a>
              )}

              <div class="feature-card__body">
                <p class="section-kicker">{fallbackBook.featureKicker || home?.featuredBookKicker || 'Featured Novel'}</p>
                <h2>{fallbackBook.title}</h2>
                {fallbackBook.subtitle && <p class="book-subtitle">{fallbackBook.subtitle}</p>}
                {formatRelease(fallbackBook) && <p class="release-note">{formatRelease(fallbackBook)}</p>}
                {fallbackBook.blurb && <p class="book-blurb">{fallbackBook.blurb}</p>}
                <div class="cta-row cta-row--compact">
                  {fallbackBook.ctas?.length ? (
                    fallbackBook.ctas.map((cta: any) => (
                      <a class={`button button--${cta.style || 'primary'}`} href={resolveLink(cta.link)}>{cta.label}</a>
                    ))
                  ) : (
                    <>
                      <a class="button button--primary" href={fallbackBook.slug?.current ? `/books/${fallbackBook.slug.current}` : '#'}>Read the Sample</a>
                      <a class="button button--ghost" href="#">Buy the Book</a>
                    </>
                  )}
                </div>
              </div>
            </div>
          </div>
        </section>
      )}

      <section class="section section--pillars">
        <div class="container">
          <div class="section-heading">
            <p class="section-kicker">{home?.pillarsKicker || 'What you’ll find here'}</p>
            <h2>{home?.pillarsHeading || 'Modern fantasy with a moral spine.'}</h2>
          </div>
          <div class="row g-4">
            {pillars.map((pillar: any) => (
              <div class="col-md-4">
                <article class="pillar-card">
                  <h3>{pillar.title}</h3>
                  <p>{pillar.body}</p>
                </article>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="author" class="section section--author">
        <div class="container container--narrow">
          <p class="section-kicker">{home?.authorKicker || 'Author Note'}</p>
          <h2>{home?.authorHeading || 'Nathan Rhys writes stories about hidden beauty, costly courage, and the choice to protect what is good.'}</h2>
          <p>{home?.authorStatement || 'I write modern fantasy for readers who want wonder without weightlessness: stories where choices matter, power has a cost, and hope is earned rather than handed out.'}</p>
        </div>
      </section>
    </main>
</Layout>
