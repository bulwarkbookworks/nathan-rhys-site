---
import { client, LAYOUT_QUERY_FRAGMENT, SECTION_QUERY, NEWSLETTERS_SLUG } from '../../lib/sanity';
import Layout from '../../layouts/Layout.astro';
import PageSection from '../../components/PageSection.astro';
import MailerliteUniversal from '../../components/MailerliteUniversal.astro';

export async function getStaticPaths() {
  return [
    { params: { newslettersSlug: NEWSLETTERS_SLUG } }
  ];
}

const page = await client.fetch(`*[_type == "newsletterThankYou"][0]{
  ...,
  ${SECTION_QUERY}
}`);

if (!page) {
  return Astro.redirect('/404');
}

const hasMailerlite = page.sections?.some((s: any) => 
  s._type === 'mailerliteSection' || 
  s.ctas?.some((c: any) => c._type === 'mailerliteCTA')
);

const title = page.title || 'Thank You';
const heading = page.heading || title;
const kicker = page.kicker;
const metadata = {
  ...page.metadata,
  excludeFromSitemap: page.excludeFromSitemap
};
---

<Layout title={title} metadata={metadata} displayLastUpdated={page?.displayLastUpdated} updatedAt={page?._updatedAt}>
  {hasMailerlite && <MailerliteUniversal slot="head" />}
  <div class="container py-24">
    <div class="standard-page">
      <header class="mb-16">
        {kicker && <p class="text-secondary font-bold uppercase tracking-wider mb-2">{kicker}</p>}
        <h1 class="text-5xl md:text-7xl mb-4">{heading}</h1>
      </header>

      {page.sections?.map((section: any) => (
          <PageSection section={section} />
      ))}
    </div>
  </div>
</Layout>
