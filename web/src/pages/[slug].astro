---
import { client, LAYOUT_QUERY_FRAGMENT, SECTION_QUERY, HOW_I_WORK_QUERY } from '../lib/sanity';
import StandardPageTemplate from '../components/StandardPageTemplate.astro';
import HowIWorkTemplate from '../components/HowIWorkTemplate.astro';
import BookTemplate from '../components/BookTemplate.astro';

export async function getStaticPaths() {
  const standardPages = await client.fetch(`*[_type == "standardPage"]{ "slug": slug.current }`);
  const standaloneBooks = await client.fetch(`*[_type == "book" && !defined(series)]{ "slug": slug.current }`);
  const howIWorkPage = await client.fetch(`*[_type == "howIWorkPage"][0]{ "slug": slug.current }`);
  
  const paths = [
    ...standardPages.map((page: any) => ({
      params: { slug: page.slug },
      props: { type: 'standardPage' }
    })),
    ...standaloneBooks.map((book: any) => ({
      params: { slug: book.slug },
      props: { type: 'book' }
    }))
  ];

  if (howIWorkPage?.slug) {
    paths.push({
      params: { slug: howIWorkPage.slug },
      props: { type: 'howIWorkPage' }
    });
  }

  return paths;
}

const { slug } = Astro.params;
const { type } = Astro.props;

let data;
if (type === 'standardPage') {
  data = await client.fetch(`*[_type == "standardPage" && slug.current == $slug][0]{
    ...,
    ${SECTION_QUERY}
  }`, { slug });
} else if (type === 'howIWorkPage') {
  data = await client.fetch(HOW_I_WORK_QUERY, { slug });
} else {
  data = await client.fetch(`*[_type == "book" && slug.current == $slug][0]{ 
    ..., 
    series->{ name, slug }, 
    "seriesSlug": series->slug.current,
    chapters[]->{ title, slug },
    ${SECTION_QUERY}
  }`, { slug });
}

if (!data) {
  return Astro.redirect('/404');
}
---

{type === 'standardPage' ? (
  <StandardPageTemplate page={data} />
) : type === 'howIWorkPage' ? (
  <HowIWorkTemplate page={data} />
) : (
  <BookTemplate book={data} />
)}
