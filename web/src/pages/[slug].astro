---
import { client } from '../lib/sanity';
import StandardPageTemplate from '../components/StandardPageTemplate.astro';
import BookTemplate from '../components/BookTemplate.astro';

export async function getStaticPaths() {
  const standardPages = await client.fetch(`*[_type == "standardPage"]{ "slug": slug.current }`);
  const standaloneBooks = await client.fetch(`*[_type == "book" && !defined(series)]{ "slug": slug.current }`);
  
  return [
    ...standardPages.map((page: any) => ({
      params: { slug: page.slug },
      props: { type: 'standardPage' }
    })),
    ...standaloneBooks.map((book: any) => ({
      params: { slug: book.slug },
      props: { type: 'book' }
    }))
  ];
}

const { slug } = Astro.params;
const { type } = Astro.props;

let data;
if (type === 'standardPage') {
  data = await client.fetch(`*[_type == "standardPage" && slug.current == $slug][0]{
    ...,
    sections[]{
      ...,
      _type == "listSection" => {
        items[]{
          ...,
          content[],
          glyphiconColor
        }
      },
      _type == "richTextSection" => {
        content[]
      }
    },
    "layout": layout->{
      ...,
      topNavigation->{
        items[]{
          label,
          link{
            ...,
            internal->{ 
              _type, 
              slug,
              _type == "book" => {
                series->{ "slug": slug }
              }
            }
          }
        }
      }
    }
  }`, { slug });
} else {
  data = await client.fetch(`*[_type == "book" && slug.current == $slug][0]{ 
    ..., 
    series->{ name, slug }, 
    chapters[]->{ title, slug } 
  }`, { slug });
}

if (!data) {
  return Astro.redirect('/404');
}
---

{type === 'standardPage' ? (
  <StandardPageTemplate page={data} />
) : (
  <BookTemplate book={data} />
)}
